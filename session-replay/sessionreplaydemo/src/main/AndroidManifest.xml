<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".MainApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SessionReplayDemo"
        tools:targetApi="31">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.jokes.JokesActivity"
            android:exported="false"
            android:label="@string/jokes_screen_title" />
        <activity
            android:name=".ui.safecontainer.SafeContainerTestActivity"
            android:exported="false"
            android:label="@string/safe_container_test_title" />
        <activity
            android:name=".ui.imageheuristic.ImageHeuristicActivity"
            android:exported="false"
            android:label="Image Heuristic Test" />
        <activity
            android:name=".ui.maskingstandard.MaskingStandardXmlActivity"
            android:exported="false"
            android:label="Masking Standard (XML)" />
        <activity
            android:name=".ui.maskingstandard.MaskingStandardComposeActivity"
            android:exported="false"
            android:label="Masking Standard (Compose)" />
        <!--DUMP permission allows adb to send broadcasts for testing purposes (not production).
            While unconventional, this reliably works
            with adb broadcasts on recent Android versions. -->
        <receiver
            android:name=".BackgroundTestReceiver"
            android:exported="true"
            android:permission="android.permission.DUMP">
            <intent-filter>
                <action android:name="com.mixpanel.sessionreplaydemo.BACKGROUND_TEST" />
            </intent-filter>
        </receiver>
        <meta-data
            android:name="com.mixpanel.android.MPConfig.EnableDebugLogging"
            android:value="true" />
    </application>

</manifest>
