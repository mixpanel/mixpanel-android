<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/safe_container_test_title"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/safe_container_test_subtitle"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- Test Case 1: Basic Safe Container with TextView and ImageView -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/test_case_1_title"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/safeContainerBasic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#E8F5E9"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/test_case_1_desc"
                android:textSize="12sp"
                android:textColor="#2E7D32"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/textViewInSafeContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sample_text_content"
                android:textSize="16sp"
                android:padding="8dp"
                android:background="#C8E6C9" />

            <ImageView
                android:id="@+id/imageViewInSafeContainer"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="8dp"
                android:background="#A5D6A7"
                android:contentDescription="@string/sample_image_desc" />
        </LinearLayout>

        <!-- Test Case 2: EditText in Safe Container (Always Masked) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/test_case_2_title"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/safeContainerWithEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#FFF3E0"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/test_case_2_desc"
                android:textSize="12sp"
                android:textColor="#E65100"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/editTextInSafeContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/edit_text_hint"
                android:text="@string/sensitive_input"
                android:padding="12dp"
                android:background="#FFE0B2"
                android:importantForAutofill="no"
                android:inputType="text" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/safe_text_in_same_container"
                android:textSize="14sp"
                android:padding="8dp"
                android:background="#FFCC80" />
        </LinearLayout>

        <!-- Test Case 3: Nested Safe Containers -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/test_case_3_title"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/nestedSafeContainerLevel1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#E3F2FD"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/test_case_3_level1"
                android:textSize="12sp"
                android:textColor="#1565C0"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/nestedSafeContainerLevel2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="#BBDEFB">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/test_case_3_level2"
                    android:textSize="12sp"
                    android:textColor="#1976D2"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:id="@+id/nestedSafeContainerLevel3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:background="#90CAF9">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/test_case_3_level3"
                        android:textSize="12sp"
                        android:textColor="#0D47A1"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/textViewInNestedContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/nested_text_content"
                        android:textSize="14sp"
                        android:padding="8dp"
                        android:background="#64B5F6" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Test Case 4: Compose Safe Container (ComposeView) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/test_case_4_title"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <androidx.compose.ui.platform.ComposeView
            android:id="@+id/composeTestSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp" />

        <!-- Instructions -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/test_instructions"
            android:textSize="12sp"
            android:textStyle="italic"
            android:padding="12dp"
            android:background="#F5F5F5"
            android:layout_marginTop="16dp" />
    </LinearLayout>
</ScrollView>
